rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function underLimit() {
      return request.resource != null && request.resource.size < 200 * 1024 * 1024;
    }

    function allowedMedia() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType.matches('video/.*')
        || request.resource.contentType.matches('audio/.*');
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && request.auth.uid == userId
        && underLimit() && allowedMedia();
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /public/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == userId
        && underLimit() && allowedMedia();
      allow delete: if signedIn() && request.auth.uid == userId;
    }
  }
}
