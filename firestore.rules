rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsResource() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function isBlocked(otherUserId) {
      return signedIn()
        && (exists(/databases/$(database)/documents/blocks/$(request.auth.uid + '_' + otherUserId))
          || exists(/databases/$(database)/documents/blocks/$(otherUserId + '_' + request.auth.uid)));
    }

    function canReadPost(postId) {
      let post = get(/databases/$(database)/documents/posts/$(postId));
      return post.data.deletedAt == null
        && (post.data.visibility == 'public'
          || (signedIn() && post.data.authorId == request.auth.uid))
        && (!signedIn() || !isBlocked(post.data.authorId));
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create, update, delete: if owns(userId);

      match /devices/{deviceId} {
        allow read, write: if owns(userId);
      }
    }

    match /projects/{projectId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsResource();

      match /versions/{versionId} {
        allow read, write: if signedIn()
          && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId
            == request.auth.uid;
      }
    }

    match /mediaAssets/{assetId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsResource();
    }

    match /posts/{postId} {
      allow read: if resource.data.deletedAt == null
        && (resource.data.visibility == 'public'
          || (signedIn() && resource.data.authorId == request.auth.uid))
        && (!signedIn() || !isBlocked(resource.data.authorId));
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.authorId == request.auth.uid;
    }

    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followingId != request.auth.uid;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /reactions/{reactionId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /comments/{commentId} {
      allow read: if resource.data.deletedAt == null
        && canReadPost(resource.data.postId);
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && canReadPost(request.resource.data.postId);
      allow update, delete: if signedIn() && resource.data.authorId == request.auth.uid;
    }

    match /savedPosts/{savedId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /blocks/{blockId} {
      allow create: if signedIn()
        && request.resource.data.blockerId == request.auth.uid;
      allow read, delete: if signedIn()
        && resource.data.blockerId == request.auth.uid;
      allow update: if false;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn()
        && resource.data.recipientId == request.auth.uid;
      allow create: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid;
      allow read: if signedIn() && resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }

    match /shareLinks/{shareId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsResource();
    }
  }
}
